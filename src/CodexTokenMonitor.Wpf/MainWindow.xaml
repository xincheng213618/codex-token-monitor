<Window x:Class="CodexTokenMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CodexTokenMonitor"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Codex Token 额度监控器"
        MinWidth="1060"
        MinHeight="720"
        Width="1380"
        Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#F6F8FB"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#E5EAF2" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D9E2EE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="#15806A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#126D5B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatusLinkButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#4D5C70" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E8EEF5" />
                                <Setter Property="Foreground" Value="#102033" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SourceTabsStyle" TargetType="TabControl">
            <Setter Property="Background" Value="#E8EEF5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="SelectedIndex" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <TabPanel IsItemsHost="True"
                                      HorizontalAlignment="Left"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#4D5C70" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="14,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="White" />
                                <Setter Property="Foreground" Value="#102033" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F6F8FB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MetricCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5A6777" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D2837" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="QuotaCaption" TargetType="TextBlock" BasedOn="{StaticResource MetricCaption}">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,0,1" />
        </Style>
        <Style x:Key="QuotaValue" TargetType="TextBlock" BasedOn="{StaticResource MetricValue}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="LineHeight" Value="22" />
        </Style>
        <Style x:Key="QuotaDetail" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#657282" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D6E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#D6E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="24" />
            <Setter Property="ColumnHeaderHeight" Value="28" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FAFCFE" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF3F8" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F6F8FB" />
            <Setter Property="Foreground" Value="#5A6777" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="6,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="16,12,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TabControl x:Name="SourceTabs"
                        Grid.Column="0"
                        Width="416"
                        Height="34"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SourceTabsStyle}"
                        SelectionChanged="SourceTabs_SelectionChanged">
                <TabItem Header="Codex" />
                <TabItem Header="Claude Code" />
                <TabItem Header="ZCode" />
                <TabItem Header="WorkBuddy" />
            </TabControl>
            <Button x:Name="CacheStatusButton"
                    Grid.Column="1"
                    Style="{StaticResource StatusLinkButton}"
                    Content="缓存详情"
                    ToolTip="查看后台缓存进度与运行信息"
                    Click="CacheStatusButton_Click" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="DataTransferButton"
                        Style="{StaticResource ToolButton}"
                        Content="数据管理"
                        ToolTip="导入或导出跨电脑 Codex 统计数据"
                        Click="DataTransferButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="导入其他电脑数据..."
                                      ToolTip="仅合并同一 Codex 账户的数据"
                                      Click="ImportDataButton_Click" />
                            <MenuItem Header="导出本机数据..."
                                      ToolTip="导出本机已缓存的 Codex 用量和额度快照"
                                      Click="ExportDataButton_Click" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button x:Name="ResetSettingsButton" Style="{StaticResource ToolButton}" Content="重置设置" Click="ResetSettingsButton_Click" />
                <Button x:Name="PlanSettingsButton" Style="{StaticResource ToolButton}" Content="套餐设置" Click="PlanSettingsButton_Click" />
                <Button Style="{StaticResource ToolButton}" Content="价格设置" Margin="0" Click="PriceSettingsButton_Click" />
            </StackPanel>
        </Grid>

        <Border x:Name="QuotaPanel"
                Grid.Row="1"
                Style="{StaticResource PanelBorder}"
                Padding="12,7"
                Margin="0,0,0,6"
                Visibility="Collapsed"
                ToolTip="优先通过 Codex 本地 app-server 实时读取；不可用时回退到本机会话日志">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.85*" />
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="0.85*" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="76" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource QuotaCaption}" Text="5h 额度" />
                    <TextBlock x:Name="Quota5hValue" Style="{StaticResource QuotaValue}" Text="5h" />
                    <TextBlock x:Name="Quota5hDetail" Style="{StaticResource QuotaDetail}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource QuotaCaption}" Text="7d 额度" />
                    <TextBlock x:Name="QuotaWeekValue" Style="{StaticResource QuotaValue}" Text="周" />
                    <TextBlock x:Name="QuotaWeekDetail" Style="{StaticResource QuotaDetail}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource QuotaCaption}" Text="当前套餐" />
                    <TextBlock x:Name="PlanSpendValue" Style="{StaticResource QuotaValue}" Text="-" />
                    <TextBlock x:Name="PlanSpendDetail" Style="{StaticResource QuotaDetail}" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource QuotaCaption}" Text="重置过期" />
                    <TextBlock x:Name="ResetOpportunityValue" Style="{StaticResource QuotaValue}" Text="-" />
                    <TextBlock x:Name="ResetOpportunityDetail" Style="{StaticResource QuotaDetail}" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource QuotaCaption}" Text="重置评估" />
                    <TextBlock x:Name="ResetPaceValue" Style="{StaticResource QuotaValue}" Text="-" />
                    <TextBlock x:Name="ResetPaceDetail" Style="{StaticResource QuotaDetail}" />
                </StackPanel>
                <Button x:Name="QuotaEstimateButton"
                        Grid.Column="5"
                        Style="{StaticResource PrimaryButton}"
                        Content="估算"
                        Width="74"
                        VerticalAlignment="Center"
                        Margin="0"
                        Click="QuotaEstimateButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="10,6" Margin="0,0,0,6">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="RangeModeBox" Width="104" Margin="0,0,10,0" SelectionChanged="RangeModeBox_SelectionChanged" />
                <Button x:Name="PreviousButton" Style="{StaticResource ToolButton}" Width="40" Content="&lt;" Click="PreviousButton_Click" />
                <DatePicker x:Name="DatePicker" Width="140" Margin="0,0,8,0" SelectedDateChanged="DatePicker_SelectedDateChanged" />
                <xctk:DateTimePicker x:Name="WeekEndPicker"
                                     Width="188"
                                     Format="Custom"
                                     FormatString="yyyy-MM-dd HH:mm"
                                     Margin="0,0,8,0"
                                     Visibility="Collapsed"
                                     ValueChanged="WeekEndPicker_ValueChanged" />
                <ComboBox x:Name="CycleBox" Width="310" Margin="0,0,8,0" Visibility="Collapsed" SelectionChanged="CycleBox_SelectionChanged" />
                <Button x:Name="WeekPickerButton" Style="{StaticResource ToolButton}" Width="74" Content="选7天" Visibility="Collapsed" Click="WeekPickerButton_Click" />
                <Button x:Name="NextButton" Style="{StaticResource ToolButton}" Width="40" Content="&gt;" Click="NextButton_Click" />
                <Button x:Name="CurrentButton" Style="{StaticResource ToolButton}" Width="86" Content="今天" Click="CurrentButton_Click" />
                <Button x:Name="StartNowButton" Style="{StaticResource ToolButton}" Width="110" Content="从当前算" Click="StartNowButton_Click" />
                <Button x:Name="RefreshDayButton" Style="{StaticResource ToolButton}" Width="68" Content="刷新日" Click="RefreshDayButton_Click" />
                <xctk:DateTimePicker x:Name="CustomStartPicker"
                                     Width="214"
                                     Format="Custom"
                                     FormatString="yyyy-MM-dd HH:mm:ss"
                                     Visibility="Collapsed"
                                     ValueChanged="CustomStartPicker_ValueChanged" />
            </StackPanel>
        </Border>

        <Border x:Name="UsageSummaryPanel" Grid.Row="3" Style="{StaticResource PanelBorder}" Padding="18,7" Height="112" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="#5A6777" FontWeight="SemiBold" FontSize="12" Text="TOTAL TOKENS" />
                    <TextBlock x:Name="TotalValue" FontSize="32" FontWeight="Bold" Foreground="#127261" Text="-" />
                    <TextBlock x:Name="PeriodValue" Foreground="#657282" FontSize="12" Text="-" TextWrapping="Wrap" />
                </StackPanel>
                <ScrollViewer x:Name="CostCardsViewport"
                              Grid.Column="1"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              ClipToBounds="True"
                              Focusable="False"
                              SizeChanged="CostCardsViewport_SizeChanged">
                    <StackPanel x:Name="CostCardsPanel" Orientation="Horizontal" />
                </ScrollViewer>
            </Grid>
        </Border>

        <UniformGrid x:Name="UsageMetricsPanel" Grid.Row="4" Columns="4" Rows="2" Height="118" Margin="0,0,0,6">
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Input" /><TextBlock x:Name="InputValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Cached" /><TextBlock x:Name="CachedValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Uncached" /><TextBlock x:Name="UncachedValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Output" /><TextBlock x:Name="OutputValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Reasoning" /><TextBlock x:Name="ReasoningValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Cache Ratio" /><TextBlock x:Name="CacheRatioValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Events" /><TextBlock x:Name="EventsValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Coding Time" /><TextBlock x:Name="CodingTimeValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
        </UniformGrid>

        <Border x:Name="UsageDetailsPanel" Grid.Row="5" Style="{StaticResource PanelBorder}" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TimelineRow" Height="0" />
                    <RowDefinition x:Name="TimelineSplitterRow" Height="0" />
                    <RowDefinition x:Name="BreakdownRow" Height="*" MinHeight="96" />
                </Grid.RowDefinitions>
                <Grid x:Name="TimelineHost" Grid.Row="0" Visibility="Collapsed">
                    <local:WpfTokenTimelineControl x:Name="Timeline" />
                </Grid>
                <GridSplitter x:Name="TimelineSplitter"
                              Grid.Row="1"
                              Height="4"
                              Margin="0,3"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#D6E0EA"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True"
                              Visibility="Collapsed" />
                <DataGrid x:Name="BreakdownGrid"
                          Grid.Row="2"
                          FrozenColumnCount="1"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True" />
            </Grid>
        </Border>

        <Border x:Name="EmptyUsagePanel"
                Grid.Row="3"
                Grid.RowSpan="3"
                Style="{StaticResource PanelBorder}"
                Padding="28"
                Visibility="Collapsed">
            <StackPanel MaxWidth="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        TextBlock.TextAlignment="Center">
                <Border Width="56"
                        Height="56"
                        Margin="0,0,0,14"
                        HorizontalAlignment="Center"
                        Background="#E8F4F1"
                        CornerRadius="28">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#127261"
                               FontSize="22"
                               FontWeight="Bold"
                               Text="0" />
                </Border>
                <TextBlock x:Name="EmptyUsageTitle"
                           Foreground="#1D2837"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Text="当前时段暂无用量" />
                <TextBlock x:Name="EmptyUsagePeriod"
                           Margin="0,8,0,0"
                           Foreground="#657282"
                           FontSize="12.5"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="EmptyUsageHint"
                           Margin="0,14,0,0"
                           Foreground="#4D5C70"
                           FontSize="13"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="6" Margin="0,16,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox x:Name="AutoRefreshBox" Content="自动刷新" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0" />
                <TextBlock x:Name="StatusText" Text="准备就绪" Foreground="#576374" VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
