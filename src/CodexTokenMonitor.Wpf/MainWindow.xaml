<Window x:Class="CodexTokenMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CodexTokenMonitor"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Codex Token 额度监控器"
        MinWidth="1100"
        MinHeight="820"
        Width="1380"
        Height="980"
        WindowStartupLocation="CenterScreen"
        Background="#F6F8FB"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#E5EAF2" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D9E2EE" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="#15806A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#126D5B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SourceTabsStyle" TargetType="TabControl">
            <Setter Property="Background" Value="#E8EEF5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <TabPanel IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#4D5C70" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="14,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="White" />
                                <Setter Property="Foreground" Value="#102033" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F6F8FB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MetricCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5A6777" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D2837" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="28" />
            <Setter Property="ColumnHeaderHeight" Value="32" />
            <Setter Property="Background" Value="White" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FAFCFE" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF3F8" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F6F8FB" />
            <Setter Property="Foreground" Value="#5A6777" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="20,14,20,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TabControl x:Name="SourceTabs"
                        Grid.Column="0"
                        Width="278"
                        Height="34"
                        HorizontalAlignment="Left"
                        Style="{StaticResource SourceTabsStyle}"
                        SelectionChanged="SourceTabs_SelectionChanged">
                <TabItem Header="Codex" />
                <TabItem Header="Claude Code" />
                <TabItem Header="ZCode" />
            </TabControl>
            <TextBlock x:Name="QueryStatusText"
                       Grid.Column="1"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       Foreground="#576374"
                       TextTrimming="CharacterEllipsis" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResetSettingsButton" Style="{StaticResource ToolButton}" Content="重置设置" Click="ResetSettingsButton_Click" />
                <Button x:Name="PlanSettingsButton" Style="{StaticResource ToolButton}" Content="套餐设置" Click="PlanSettingsButton_Click" />
                <Button Style="{StaticResource ToolButton}" Content="价格设置" Margin="0" Click="PriceSettingsButton_Click" />
            </StackPanel>
        </Grid>

        <Border x:Name="QuotaPanel" Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="18,10" Margin="0,0,0,10" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource MetricCaption}" Text="5h 额度" />
                    <TextBlock x:Name="Quota5hValue" Style="{StaticResource MetricValue}" Text="5h" />
                    <TextBlock x:Name="Quota5hDetail" Foreground="#657282" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource MetricCaption}" Text="7d 额度" />
                    <TextBlock x:Name="QuotaWeekValue" Style="{StaticResource MetricValue}" Text="周" />
                    <TextBlock x:Name="QuotaWeekDetail" Foreground="#657282" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource MetricCaption}" Text="当前套餐" />
                    <TextBlock x:Name="PlanSpendValue" Style="{StaticResource MetricValue}" Text="-" />
                    <TextBlock x:Name="PlanSpendDetail" Foreground="#657282" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource MetricCaption}" Text="重置过期" />
                    <TextBlock x:Name="ResetOpportunityValue" Style="{StaticResource MetricValue}" Text="-" />
                    <TextBlock x:Name="ResetOpportunityDetail" Foreground="#657282" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="4" Margin="0,0,12,0">
                    <TextBlock Style="{StaticResource MetricCaption}" Text="重置评估" />
                    <TextBlock x:Name="ResetPaceValue" Style="{StaticResource MetricValue}" Text="-" />
                    <TextBlock x:Name="ResetPaceDetail" Foreground="#657282" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button x:Name="QuotaEstimateButton"
                        Grid.Column="5"
                        Style="{StaticResource PrimaryButton}"
                        Content="估算"
                        VerticalAlignment="Center"
                        Margin="0"
                        Click="QuotaEstimateButton_Click" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="14,10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="RangeModeBox" Width="110" Margin="0,0,12,0" SelectionChanged="RangeModeBox_SelectionChanged" />
                <Button x:Name="PreviousButton" Style="{StaticResource ToolButton}" Width="42" Content="&lt;" Click="PreviousButton_Click" />
                <DatePicker x:Name="DatePicker" Width="150" Margin="0,0,8,0" SelectedDateChanged="DatePicker_SelectedDateChanged" />
                <xctk:DateTimePicker x:Name="WeekEndPicker"
                                     Width="196"
                                     Format="Custom"
                                     FormatString="yyyy-MM-dd HH:mm"
                                     Margin="0,0,8,0"
                                     Visibility="Collapsed"
                                     ValueChanged="WeekEndPicker_ValueChanged" />
                <ComboBox x:Name="CycleBox" Width="330" Margin="0,0,8,0" Visibility="Collapsed" SelectionChanged="CycleBox_SelectionChanged" />
                <Button x:Name="WeekPickerButton" Style="{StaticResource ToolButton}" Width="78" Content="选7天" Visibility="Collapsed" Click="WeekPickerButton_Click" />
                <Button x:Name="NextButton" Style="{StaticResource ToolButton}" Width="42" Content="&gt;" Click="NextButton_Click" />
                <Button x:Name="CurrentButton" Style="{StaticResource ToolButton}" Width="92" Content="今天" Click="CurrentButton_Click" />
                <Button x:Name="StartNowButton" Style="{StaticResource ToolButton}" Width="118" Content="从当前算" Click="StartNowButton_Click" />
                <Button x:Name="RefreshDayButton" Style="{StaticResource ToolButton}" Width="72" Content="刷新日" Click="RefreshDayButton_Click" />
                <xctk:DateTimePicker x:Name="CustomStartPicker"
                                     Width="226"
                                     Format="Custom"
                                     FormatString="yyyy-MM-dd HH:mm:ss"
                                     Visibility="Collapsed"
                                     ValueChanged="CustomStartPicker_ValueChanged" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource PanelBorder}" Padding="22,8" Height="126" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="5*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Foreground="#5A6777" FontWeight="SemiBold" Text="总 Token" />
                    <TextBlock x:Name="TotalValue" FontSize="34" FontWeight="Bold" Foreground="#18212F" Text="-" />
                    <TextBlock x:Name="PeriodValue" Foreground="#657282" Text="-" TextWrapping="Wrap" />
                </StackPanel>
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="CostCardsPanel">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="4" Columns="4" Rows="2" Height="224" Margin="0,0,0,12">
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Input" /><TextBlock x:Name="InputValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Cached" /><TextBlock x:Name="CachedValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Uncached" /><TextBlock x:Name="UncachedValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Output" /><TextBlock x:Name="OutputValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Reasoning" /><TextBlock x:Name="ReasoningValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Cache Ratio" /><TextBlock x:Name="CacheRatioValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Events" /><TextBlock x:Name="EventsValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorder}" Margin="0">
                <StackPanel><TextBlock Style="{StaticResource MetricCaption}" Text="Coding Time" /><TextBlock x:Name="CodingTimeValue" Style="{StaticResource MetricValue}" Text="-" /></StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="5" Style="{StaticResource PanelBorder}" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="TimelineRow" Height="0" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid x:Name="TimelineHost" Grid.Row="0" Margin="0,0,0,12" Visibility="Collapsed">
                    <local:WpfTokenTimelineControl x:Name="Timeline" />
                    <Button x:Name="TimelineResetButton"
                            Style="{StaticResource ToolButton}"
                            Content="重置视图"
                            MinHeight="28"
                            Padding="10,0"
                            Margin="0,8,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            ToolTip="恢复完整时间范围"
                            Click="TimelineResetButton_Click" />
                </Grid>
                <DataGrid x:Name="BreakdownGrid" Grid.Row="1" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="6" Margin="0,16,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <CheckBox x:Name="AutoRefreshBox" Content="自动刷新" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0" />
                <TextBlock x:Name="StatusText" Text="准备就绪" Foreground="#576374" VerticalAlignment="Center" Margin="0,0,24,0" />
                <Button x:Name="ClearCacheButton" Style="{StaticResource ToolButton}" Content="清缓存" Click="ClearCacheButton_Click" />
                <Button x:Name="RefreshButton" Style="{StaticResource PrimaryButton}" Content="刷新" Margin="0" Click="RefreshButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
