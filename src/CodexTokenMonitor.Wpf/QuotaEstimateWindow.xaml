<Window x:Class="CodexTokenMonitor.QuotaEstimateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Codex 额度估算"
        Width="1360"
        Height="980"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FB"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#15806A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowHeight" Value="28" />
            <Setter Property="ColumnHeaderHeight" Value="32" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF3F8" />
            <Setter Property="AlternatingRowBackground" Value="#FAFCFE" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F6F8FB" />
            <Setter Property="Foreground" Value="#5A6777" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="176" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="268" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}" Text="当前窗口" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.15*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="142" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Bold" Foreground="#374151" Text="5h" VerticalAlignment="Center" />
                    <TextBlock x:Name="FiveHourPlan" Grid.Row="0" Grid.Column="1" Foreground="#576374" TextAlignment="Right" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock x:Name="FiveHourValue" Grid.Row="1" Grid.Column="0" FontFamily="Segoe UI" FontSize="32" FontWeight="Bold" Foreground="#1D2837" Text="-" VerticalAlignment="Center" />
                    <TextBlock x:Name="FiveHourDetail" Grid.Row="1" Grid.Column="1" Foreground="#374151" Text="-" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock x:Name="FiveHourStable" Grid.Row="2" Grid.ColumnSpan="2" Foreground="#576374" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="8,0,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="142" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="34" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" FontWeight="Bold" Foreground="#374151" Text="7d" VerticalAlignment="Center" />
                    <TextBlock x:Name="WeekPlan" Grid.Row="0" Grid.Column="1" Foreground="#576374" TextAlignment="Right" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock x:Name="WeekValue" Grid.Row="1" Grid.Column="0" FontFamily="Segoe UI" FontSize="32" FontWeight="Bold" Foreground="#1D2837" Text="-" VerticalAlignment="Center" />
                    <TextBlock x:Name="WeekDetail" Grid.Row="1" Grid.Column="1" Foreground="#374151" Text="-" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <TextBlock x:Name="WeekStable" Grid.Row="2" Grid.ColumnSpan="2" Foreground="#576374" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="8,0,0,0">
                <StackPanel x:Name="ResetOpportunityPanel" />
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Height="58" Padding="12,8" Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="7d 手动估算" FontWeight="Bold" Foreground="#1F2937" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock DockPanel.Dock="Left" Text="剩余" Foreground="#576374" VerticalAlignment="Center" Margin="0,0,6,0" />
                <xctk:DecimalUpDown x:Name="ManualFromBox" DockPanel.Dock="Left" Width="58" Minimum="0" Maximum="100" Increment="1" Value="90" FormatString="F0" TextAlignment="Right" Margin="0,0,4,0" />
                <TextBlock DockPanel.Dock="Left" Text="% ->" Foreground="#576374" VerticalAlignment="Center" Margin="0,0,6,0" />
                <xctk:DecimalUpDown x:Name="ManualToBox" DockPanel.Dock="Left" Width="58" Minimum="0" Maximum="100" Increment="1" Value="85" FormatString="F0" TextAlignment="Right" Margin="0,0,4,0" />
                <TextBlock DockPanel.Dock="Left" Text="%" Foreground="#576374" VerticalAlignment="Center" Margin="0,0,10,0" />
                <Button x:Name="ManualEstimateButton" DockPanel.Dock="Left" Style="{StaticResource PrimaryButton}" Content="估算" Width="72" MinWidth="72" Margin="0,0,12,0" Click="ManualEstimateButton_Click" />
                <Button DockPanel.Dock="Left" Style="{StaticResource PrimaryButton}" Content="放大曲线" Width="96" MinWidth="96" Margin="0,0,12,0" Click="QuotaCurveButton_Click" />
                <TextBlock x:Name="ManualResultText" Foreground="#374151" Text="输入剩余百分比后估算当前 7d 周额度" TextWrapping="Wrap" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,0,0,8">
            <TextBlock Style="{StaticResource SectionHeader}" Margin="0" Text="7d 额度与累计费用曲线" />
            <ComboBox x:Name="CurvePlanComboBox" DockPanel.Dock="Right" Width="150" Height="30"
                      VerticalContentAlignment="Center" SelectionChanged="CurvePlanComboBox_SelectionChanged" />
            <TextBlock DockPanel.Dock="Right" Text="套餐" Foreground="#576374" VerticalAlignment="Center" Margin="0,0,8,0" />
        </DockPanel>

        <Border Grid.Row="4" Background="White" BorderBrush="#E1E8F0" BorderThickness="1"
                CornerRadius="4" Padding="6" Margin="0,0,0,10">
            <ContentControl x:Name="EmbeddedCurveHost" />
        </Border>

        <TextBlock Grid.Row="5" Style="{StaticResource SectionHeader}" Text="历史 7d 周期" />

        <DataGrid x:Name="WeeklyGrid" Grid.Row="6" SelectionChanged="WeeklyGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="周期" Binding="{Binding Period}" Width="230" />
                <DataGridTextColumn Header="历时" Binding="{Binding Duration}" Width="106" />
                <DataGridTextColumn Header="重置" Binding="{Binding ResetAt}" Width="96" />
                <DataGridTextColumn Header="快照" Binding="{Binding SnapshotCount}" Width="58" />
                <DataGridTextColumn Header="剩余" Binding="{Binding Remaining}" Width="66" />
                <DataGridTextColumn Header="已用" Binding="{Binding UsedPercent}" Width="62" />
                <DataGridTextColumn Header="应%" Binding="{Binding ExpectedPercent}" Width="62" />
                <DataGridTextColumn Header="节奏" Binding="{Binding Rhythm}" Width="126" />
                <DataGridTextColumn Header="Tokens" Binding="{Binding Tokens}" Width="108" />
                <DataGridTextColumn Header="已用 $" Binding="{Binding UsedCost}" Width="82" />
                <DataGridTextColumn Header="100% $" Binding="{Binding EstimatedLimit}" Width="82" />
                <DataGridTextColumn Header="套餐" Binding="{Binding PlanNames}" Width="96" />
                <DataGridTextColumn Header="实际 ¥" Binding="{Binding PlanAmount}" Width="84" />
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="7" Margin="0,12,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Content="关闭" Click="CloseButton_Click" />
            <TextBlock x:Name="StatusText" DockPanel.Dock="Right" Text="正在加载..." Foreground="#576374" VerticalAlignment="Center" Margin="0,0,20,0" />
        </DockPanel>
    </Grid>
</Window>
