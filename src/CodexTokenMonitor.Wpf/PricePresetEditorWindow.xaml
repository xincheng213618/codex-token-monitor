<Window x:Class="CodexTokenMonitor.PricePresetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:ClassModifier="internal"
        Width="620"
        Height="590"
        MinWidth="560"
        MinHeight="540"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8FB"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#465568" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#D6E0EA" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#D6E0EA" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#15806A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="HeadingText" FontSize="19" FontWeight="Bold" Foreground="#172334" />
            <TextBlock Text="价格按每百万 token 或每 token 填写；缓存输入按 prompt cache read 价格填写。"
                       Margin="0,5,0,0" Foreground="#667387" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E1E8F0" BorderThickness="1" CornerRadius="6" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="118" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="供应商" />
                <TextBox x:Name="ProviderBox" Grid.Row="0" Grid.Column="1" />
                <TextBlock Grid.Row="1" Style="{StaticResource FieldLabel}" Text="模型名称 *" />
                <TextBox x:Name="ModelBox" Grid.Row="1" Grid.Column="1" />
                <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="币种" />
                <ComboBox x:Name="CurrencyBox" Grid.Row="2" Grid.Column="1" IsEditable="True" />
                <TextBlock Grid.Row="3" Style="{StaticResource FieldLabel}" Text="计价单位" />
                <ComboBox x:Name="UnitBox" Grid.Row="3" Grid.Column="1" IsEditable="True" />
                <TextBlock Grid.Row="4" Style="{StaticResource FieldLabel}" Text="未缓存输入" />
                <TextBox x:Name="InputBox" Grid.Row="4" Grid.Column="1" HorizontalContentAlignment="Right" />
                <TextBlock Grid.Row="5" Style="{StaticResource FieldLabel}" Text="缓存输入" />
                <TextBox x:Name="CachedBox" Grid.Row="5" Grid.Column="1" HorizontalContentAlignment="Right" />
                <TextBlock Grid.Row="6" Style="{StaticResource FieldLabel}" Text="输出" />
                <TextBox x:Name="OutputBox" Grid.Row="6" Grid.Column="1" HorizontalContentAlignment="Right" />
                <TextBlock Grid.Row="7" Style="{StaticResource FieldLabel}" Text="价格来源" />
                <TextBox x:Name="SourceBox" Grid.Row="7" Grid.Column="1" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource PrimaryButton}" Background="#E5EAF2" Foreground="#263548" Content="取消" IsCancel="True" />
            <Button Style="{StaticResource PrimaryButton}" Content="确定" Margin="10,0,0,0" IsDefault="True" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>
